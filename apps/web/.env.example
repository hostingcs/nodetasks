# Postgres connection string (Railway plugin auto-populates DATABASE_URL)
DATABASE_URL=postgres://user:password@host:5432/db

# Admin login credentials (set both)
ADMIN_USERNAME=admin
ADMIN_PASSWORD=change-this-to-something-long

# Session signing secret — must be 32+ random characters.
# Generate one: `openssl rand -base64 48` or `node -e "console.log(require('crypto').randomBytes(48).toString('base64'))"`
AUTH_SECRET=replace-me-with-a-32-plus-char-random-string

# Salt used for daily IP-hashing in the pixel endpoint (any random string).
# Rotate to break historical dedupe; change breaks uniques graph.
PIXEL_SALT=replace-me-with-any-random-string
