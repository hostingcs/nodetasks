{
  "$schema": "https://raw.githubusercontent.com/neutralinojs/neutralinojs/main/schemas/neutralino.config.schema.json",
  "applicationId": "app.nodetasks.monitor",
  "version": "1.0.0",
  "defaultMode": "window",
  "port": 0,
  "documentRoot": "/resources/",
  "url": "/",
  "enableServer": true,
  "enableNativeAPI": true,
  "tokenSecurity": "one-time",
  "logging": {
    "enabled": true,
    "writeToLogFile": false
  },
  "globalVariables": {
    "UPDATE_MANIFEST_URL": "https://nodetasks.com/updates/manifest.json"
  },
  "nativeAllowList": [
    "app.*",
    "os.*",
    "computer.*",
    "window.*",
    "events.*",
    "updater.*",
    "debug.log"
  ],
  "modes": {
    "window": {
      "title": "NodeTasks",
      "width": 560,
      "height": 440,
      "minWidth": 420,
      "minHeight": 300,
      "center": true,
      "fullScreen": false,
      "alwaysOnTop": false,
      "icon": "/resources/icons/appIcon.png",
      "enableInspector": false,
      "borderless": false,
      "maximize": false,
      "hidden": false,
      "resizable": true,
      "exitProcessOnClose": false
    }
  },
  "cli": {
    "binaryName": "NodeTasks",
    "resourcesPath": "/resources/",
    "extensionsPath": "/extensions/",
    "clientLibrary": "/resources/js/neutralino.js",
    "binaryVersion": "6.7.0",
    "clientVersion": "6.7.0"
  }
}
